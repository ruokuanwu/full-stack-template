{
    "compilerOptions": {
        "lib": [
            "ESNext"
        ],
        "target": "ESNext",
        "module": "ESNext",
        "moduleDetection": "force",
        "allowImportingTsExtensions": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src",
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}